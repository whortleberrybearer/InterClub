---
// src/components/TeamStandingsLayout.astro
//
// Shared layout for the team standings page, used by both series.
// Three responsive views (matching IndividualStandingsLayout):
//   Mobile  (<sm)   — expandable club cards
//   Tablet  (sm–lg) — table inside a white card
//   Desktop (lg+)   — sticky sidebar + plain stacked tables
import Layout from './Layout.astro';
import PageHeader from './PageHeader.astro';
import ChipBar from './ChipBar.astro';
import MobileAccordionCard from './MobileAccordionCard.astro';
import RaceKeyItem from './RaceKeyItem.astro';
import RaceResultGrid from './RaceResultGrid.astro';
import type { RaceCell } from './RaceResultGrid.astro';
import { getRaces } from '../lib/data';
import type { Club, Series, SeriesConfig, TeamStandings } from '../lib/types';
import { siteUrl } from '../lib/url';
import { getSeriesLabel } from '../lib/format';

export interface Props {
  series: Series;
  year: number;
  standings: TeamStandings;
  clubs: Club[];
  config: SeriesConfig;
  linkedRaceIds: string[];
}

const { series, year, standings, clubs, config } = Astro.props;
const linkedRaceIds = new Set(Astro.props.linkedRaceIds);

const seriesLabel = getSeriesLabel(series);

const races = getRaces(year, series);
const clubById = Object.fromEntries(clubs.map(c => [c.id, c]));
const categoryById = Object.fromEntries((config.teamCategories ?? []).map(c => [c.id, c]));

const abbr = (t: string) => t.replace(/ points\b/g, ' pts').replace(/ teams\b/g, ' tms');

const standingsRaceIdx = Object.fromEntries(standings.races.map((id, i) => [id, i]));

const racesRun = standings.races.filter((_, idx) =>
  standings.categories.some(cat => cat.clubs.some(club => club.points[idx] !== null))
).length;

// Shared table header class strings
const tabTh = 'font-head text-[10px] font-bold tracking-[0.1em] uppercase text-muted py-2.5 px-2 bg-surface border-b-2 border-content';
const dtTh  = 'font-head text-[10px] font-bold tracking-[0.1em] uppercase text-muted py-2.5 px-2 bg-surface';

// Race column width: widen columns when there are fewer races so they spread
// evenly rather than leaving the Club column disproportionately wide.
const raceColWidth = races.length >= 7 ? '3rem'
                   : races.length >= 5 ? '4rem'
                   : races.length >= 3 ? '5rem'
                   : '6rem';
---

<Layout title={`${seriesLabel} ${year} — Team Standings`}>

  <PageHeader
    slot="hero"
    eyebrow={`${seriesLabel} ${year} · Season Standings`}
    title="Team Standings"
    provisional={standings.provisional}
  >
    <div class="flex">
      <a
        href={siteUrl(`/${series}/${year}/individual-standings`)}
        class="flex-1 md:flex-none font-head text-[13px] font-bold tracking-[0.06em] uppercase py-2.5 md:mr-7 border-b-2 -mb-px text-center md:text-left border-transparent text-hdr-muted hover:text-hdr-text transition-colors"
      >Individual</a>
      <a
        href={siteUrl(`/${series}/${year}/team-standings`)}
        class="flex-1 md:flex-none font-head text-[13px] font-bold tracking-[0.06em] uppercase py-2.5 md:mr-7 border-b-2 -mb-px text-center md:text-left border-amber text-hdr-text"
      >Team</a>
    </div>
  </PageHeader>

  <!-- Category chip bar — mobile + tablet, in the chip-bar slot (full viewport width) -->
  <ChipBar
    slot="chip-bar"
    items={standings.categories.map((cat, i) => ({
      label:  categoryById[cat.id]?.name ?? cat.id,
      target: `cat-panel-${i}`,
      active: i === 0,
    }))}
  />

  <!-- ══════════════════════════════════════════════
       DESKTOP (lg+): sticky sidebar + stacked tables
  ══════════════════════════════════════════════ -->
  <div class="hidden lg:grid grid-cols-[220px_1fr] xl:grid-cols-[260px_1fr] gap-8 items-start">

    <!-- Sticky sidebar -->
    <aside class="sticky top-6 self-start">
      <p class="font-head text-[10px] font-bold tracking-[0.12em] uppercase text-muted mb-2 pl-1">Category</p>
      <nav class="flex flex-col">
        {standings.categories.map((cat, i) => {
          const label = categoryById[cat.id]?.name ?? cat.id;
          return (
            <button
              class:list={[
                'dt-sidebar-btn w-full flex items-center px-3 py-2 rounded-lg border-l-2 text-left transition-colors font-head text-[13px] font-bold tracking-[0.04em] uppercase',
                i === 0 ? 'border-l-amber bg-amber-bg text-amber'
                        : 'border-l-transparent hover:bg-canvas text-content',
              ]}
              data-target={`dt-panel-${i}`}
            >
              <span>{label}</span>
            </button>
          );
        })}
      </nav>

      <!-- Race key -->
      <div class="mt-7 pt-5 border-t border-line">
        <p class="font-head text-[10px] font-bold tracking-[0.12em] uppercase text-muted mb-2.5 pl-1">Race Key</p>
        <div class="flex flex-col gap-1 pl-1">
          {races.map((race, ri) => {
            const ran  = racesRun > ri;
            const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
            return <RaceKeyItem label={race.shortName ?? race.id} name={race.name} href={href} ran={ran} />;
          })}
        </div>
      </div>
    </aside>

    <!-- Category panels: one visible at a time, switched by sidebar buttons -->
    <div>
      {standings.categories.map((cat, i) => {
        const label = categoryById[cat.id]?.name ?? cat.id;
        return (
          <section id={`dt-panel-${i}`} class:list={[i > 0 && 'hidden']}>
            <div class="pb-3 mb-3.5 border-b-2 border-content">
              <h2 class="font-head text-[26px] font-extrabold tracking-tight leading-none">{label}</h2>
            </div>
            <table class="w-full border-collapse text-sm table-fixed">
              <colgroup>
                <col class="w-10" />
                <col />
                {races.map(() => <col style={`width: ${raceColWidth}`} />)}
                <col class="w-16" />
              </colgroup>
              <thead>
                <tr>
                  <th class={`${dtTh} text-center`}>#</th>
                  <th class={`${dtTh} text-left`}>Club</th>
                  {races.map((race, ri) => {
                    const ran = racesRun > ri;
                    const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                    return (
                      <th class:list={[`${dtTh} text-center`, !ran && 'opacity-50']}>
                        {href
                          ? <a href={href} class="text-amber hover:underline">{race.shortName ?? race.id}</a>
                          : (race.shortName ?? race.id)
                        }
                      </th>
                    );
                  })}
                  <th class={`${dtTh} w-16 text-right border-l-2 border-content pr-0.5`}>Total</th>
                </tr>
              </thead>
              <tbody>
                {cat.clubs.map((clubResult) => {
                  const clubName = clubById[clubResult.club]?.name ?? clubResult.club;
                  return (
                    <tr class="border-b border-line last:border-0 hover:bg-canvas/50">
                      <td class="py-2.5 px-2 text-center align-middle font-mono text-xs font-medium text-muted tabular-nums">
                        {clubResult.position}
                      </td>
                      <td class="py-2.5 px-2 align-middle max-w-0 overflow-hidden">
                        <div class="flex items-center gap-2 min-w-0">
                          <img src={siteUrl(`/images/vests/${clubById[clubResult.club]?.vest ?? 'unknown-sm.png'}`)} alt="" class="h-6 w-auto shrink-0 object-contain" />
                          <span class="font-semibold text-[14px] truncate">{clubName}</span>
                        </div>
                      </td>
                      {races.map((race, ri) => {
                        const sIdx = standingsRaceIdx[race.id];
                        const pts = sIdx !== undefined ? (clubResult.points[sIdx] ?? null) : null;
                        const ran = racesRun > ri;
                        return (
                          <td class:list={[
                            'py-2.5 px-1 text-center font-mono text-[13px] align-middle tabular-nums',
                            pts === null ? 'text-content/20' : (ran ? 'font-medium' : 'text-muted'),
                          ]}>
                            {pts ?? '—'}
                          </td>
                        );
                      })}
                      <td class="py-2.5 pl-3 pr-0.5 text-right border-l-2 border-content align-top">
                        <div class="font-mono text-[17px] font-bold tabular-nums">{clubResult.total}</div>
                        {clubResult.tiebreaker && (
                          <div class="font-mono text-[10px] text-muted mt-0.5 tracking-[0.04em] whitespace-nowrap">{abbr(clubResult.tiebreaker)}</div>
                        )}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </section>
        );
      })}
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       MOBILE + TABLET (<lg): chip-switched panels
       Breakpoints unified with IndividualStandingsLayout:
         Mobile  < sm (640px) — expandable cards
         Tablet  sm–lg        — table in a card
  ══════════════════════════════════════════════ -->
  <div class="lg:hidden">
    {standings.categories.map((cat, i) => {
      const label = categoryById[cat.id]?.name ?? cat.id;
      return (
        <div id={`cat-panel-${i}`} class:list={[i > 0 && 'hidden']} role="tabpanel">

          <!-- Panel heading -->
          <div class="mb-3 sm:mb-4">
            <h2 class="font-head text-[22px] sm:text-[26px] font-extrabold tracking-tight">{label}</h2>
          </div>

          <!-- ── TABLET (sm to lg): table in a card ── -->
          <div class="hidden sm:block overflow-x-auto">
            <div class="bg-surface border border-line rounded-xl overflow-hidden">
              <table class="w-full border-collapse text-sm table-fixed">
                <colgroup>
                  <col class="w-10" />
                  <col />
                  {races.map(() => <col style={`width: ${raceColWidth}`} />)}
                  <col class="w-16" />
                </colgroup>
                <thead>
                  <tr>
                    <th class={`${tabTh} text-center`}>#</th>
                    <th class={`${tabTh} text-left pl-2`}>Club</th>
                    {races.map((race, ri) => {
                      const ran = racesRun > ri;
                      const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                      return (
                        <th class:list={[`${tabTh} text-center`, !ran && 'opacity-55']}>
                          {href
                            ? <a href={href} class="text-amber hover:underline">{race.shortName ?? race.id}</a>
                            : (race.shortName ?? race.id)
                          }
                        </th>
                      );
                    })}
                    <th class={`${tabTh} w-16 text-right border-l-2 border-content pr-3.5`}>Total</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.clubs.map((clubResult) => {
                    const clubName = clubById[clubResult.club]?.name ?? clubResult.club;
                    return (
                      <tr class="border-b border-line last:border-0 hover:bg-canvas/50">
                        <td class="py-3 pl-3.5 pr-2 text-center align-middle font-mono text-xs font-medium text-muted tabular-nums">
                          {clubResult.position}
                        </td>
                        <td class="py-3 pl-2 pr-2 align-middle max-w-0 overflow-hidden">
                          <div class="flex items-center gap-2 min-w-0">
                            {clubById[clubResult.club]?.vest && (
                              <img src={siteUrl(`/images/vests/${clubById[clubResult.club].vest}`)} alt="" class="h-6 w-auto shrink-0 object-contain" />
                            )}
                            <span class="font-semibold text-[14px] truncate">{clubName}</span>
                          </div>
                        </td>
                        {races.map((race, ri) => {
                          const sIdx = standingsRaceIdx[race.id];
                          const pts = sIdx !== undefined ? (clubResult.points[sIdx] ?? null) : null;
                          return (
                            <td class:list={[
                              'py-3 px-1 text-center font-mono text-[13px] align-middle tabular-nums',
                              pts === null ? 'text-content/20' : (racesRun > ri ? 'font-medium' : 'text-muted'),
                            ]}>
                              {pts ?? '—'}
                            </td>
                          );
                        })}
                        <td class="py-3 pl-3 pr-3.5 text-right border-l-2 border-content align-top">
                          <div class="font-mono text-[16px] font-bold tabular-nums">{clubResult.total}</div>
                          {clubResult.tiebreaker && (
                            <div class="font-mono text-[10px] text-muted mt-0.5 tracking-[0.04em] whitespace-nowrap">{abbr(clubResult.tiebreaker)}</div>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
            <!-- Race legend (tablet) -->
            <div class="flex flex-wrap gap-x-3.5 gap-y-1.5 pt-3.5">
              {races.map((race, ri) => {
                const ran  = racesRun > ri;
                const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                return <RaceKeyItem label={race.shortName ?? race.id} name={race.name} href={href} ran={ran} showUpcoming />;
              })}
            </div>
          </div>

          <!-- ── MOBILE (below sm): expandable cards ── -->
          <div class="sm:hidden pb-2">
            {cat.clubs.map((clubResult) => {
              const clubName = clubById[clubResult.club]?.name ?? clubResult.club;
              const detailId = `detail-${i}-${clubResult.club}`;
              return (
                <MobileAccordionCard detailId={detailId} position={clubResult.position}>
                  <div class="flex items-center gap-2 min-w-0">
                    <img src={siteUrl(`/images/vests/${clubById[clubResult.club]?.vest ?? 'unknown-sm.png'}`)} alt="" class="h-9 w-auto shrink-0 object-contain" />
                    <div class="font-head text-[16px] font-bold tracking-[-0.01em] leading-[1.15] truncate">{clubName}</div>
                  </div>

                  <div slot="score" class="text-right shrink-0 flex flex-col items-end justify-center min-h-10">
                    <div class="font-mono text-[22px] font-medium leading-none tabular-nums">{clubResult.total}</div>
                    {clubResult.tiebreaker && (
                      <div class="font-mono text-[9px] text-muted mt-0.5 tracking-[0.04em]">{abbr(clubResult.tiebreaker)}</div>
                    )}
                  </div>

                  <RaceResultGrid
                    slot="detail"
                    cells={races.map(race => {
                      const sIdx = standingsRaceIdx[race.id];
                      const pts  = sIdx !== undefined ? (clubResult.points[sIdx] ?? null) : null;
                      return {
                        label:    race.shortName ?? race.id,
                        href:     linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null,
                        score:    pts,
                        counting: pts !== null && pts > 0 ? true : undefined,
                      } satisfies RaceCell;
                    })}
                  />
                </MobileAccordionCard>
              );
            })}
          </div>

          <!-- Race key (mobile only) -->
          <div class="sm:hidden mt-4 pt-4 border-t border-line">
            <p class="font-head text-[10px] font-bold tracking-[0.12em] uppercase text-muted mb-2">Race Key</p>
            <div class="grid grid-cols-2 gap-x-3 gap-y-1">
              {races.map((race, ri) => {
                const ran  = racesRun > ri;
                const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                return <RaceKeyItem label={race.shortName ?? race.id} name={race.name} href={href} ran={ran} />;
              })}
            </div>
          </div>

        </div>
      );
    })}
  </div>

</Layout>

<script>
  const chips        = document.querySelectorAll<HTMLButtonElement>('.chip-btn');
  const dtSidebarBtns = document.querySelectorAll<HTMLButtonElement>('.dt-sidebar-btn');

  // Activates both views by index so resizing keeps them in sync
  function activateIndex(idx: string) {
    chips.forEach(c => {
      const active = c.dataset.target === `cat-panel-${idx}`;
      c.classList.toggle('bg-amber',     active);
      c.classList.toggle('border-amber', active);
      c.classList.toggle('text-white',   active);
      c.classList.toggle('bg-surface',   !active);
      c.classList.toggle('border-line',  !active);
      c.classList.toggle('text-muted',   !active);
      c.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    document.querySelectorAll<HTMLElement>('[id^="cat-panel-"]').forEach(panel => {
      panel.classList.toggle('hidden', panel.id !== `cat-panel-${idx}`);
    });
    dtSidebarBtns.forEach(b => {
      const active = b.dataset.target === `dt-panel-${idx}`;
      b.classList.toggle('border-l-amber',       active);
      b.classList.toggle('bg-amber-bg',          active);
      b.classList.toggle('text-amber',           active);
      b.classList.toggle('border-l-transparent', !active);
      b.classList.toggle('hover:bg-canvas',      !active);
      b.classList.toggle('text-content',         !active);
    });
    document.querySelectorAll<HTMLElement>('[id^="dt-panel-"]').forEach(panel => {
      panel.classList.toggle('hidden', panel.id !== `dt-panel-${idx}`);
    });
  }

  chips.forEach(btn => {
    btn.addEventListener('click', () => {
      activateIndex(btn.dataset.target!.replace('cat-panel-', ''));
    });
  });
  dtSidebarBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activateIndex(btn.dataset.target!.replace('dt-panel-', ''));
    });
  });

</script>
