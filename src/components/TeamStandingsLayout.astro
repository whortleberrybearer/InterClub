---
// src/components/TeamStandingsLayout.astro
//
// Shared layout for the team standings page, used by both series.
// Three responsive views (matching IndividualStandingsLayout):
//   Mobile  (<sm)   — expandable club cards
//   Tablet  (sm–lg) — table inside a white card
//   Desktop (lg+)   — sticky sidebar + plain stacked tables
import Layout from './Layout.astro';
import StandingsHeader from './StandingsHeader.astro';
import ChipBar from './ChipBar.astro';
import MobileAccordionCard from './MobileAccordionCard.astro';
import { getRaces } from '../lib/data';
import type { Club, Series, SeriesConfig, TeamStandings } from '../lib/types';
import { siteUrl } from '../lib/url';

export interface Props {
  series: Series;
  year: number;
  standings: TeamStandings;
  clubs: Club[];
  config: SeriesConfig;
  linkedRaceIds: string[];
}

const { series, year, standings, clubs, config } = Astro.props;
const linkedRaceIds = new Set(Astro.props.linkedRaceIds);

const seriesLabel = series === 'road-gp' ? 'Road GP' : 'Fell Championship';
const seriesLong  = series === 'road-gp' ? 'Road Grand Prix' : 'Fell Championship';

const races = getRaces(year, series);
const clubById = Object.fromEntries(clubs.map(c => [c.id, c]));
const categoryById = Object.fromEntries((config.teamCategories ?? []).map(c => [c.id, c]));

const standingsRaceIdx = Object.fromEntries(standings.races.map((id, i) => [id, i]));

const racesRun = standings.races.filter((_, idx) =>
  standings.categories.some(cat => cat.clubs.some(club => club.points[idx] !== null))
).length;
const racesRemaining = races.length - racesRun;

// Shared table header class strings
const tabTh = 'font-head text-[10px] font-bold tracking-[0.1em] uppercase text-muted py-2.5 px-2 bg-surface border-b-2 border-content';
const dtTh  = 'font-head text-[10px] font-bold tracking-[0.1em] uppercase text-muted py-2.5 px-2 bg-surface';
---

<Layout title={`${seriesLabel} ${year} — Team Standings`}>

  <StandingsHeader
    slot="hero"
    backHref={siteUrl(`/${series}/${year}`)}
    backLabel={`← ${seriesLabel} ${year}`}
    activeTab="team"
    individualHref={siteUrl(`/${series}/${year}/individual-standings`)}
    teamHref={siteUrl(`/${series}/${year}/team-standings`)}
  >
    <p class="font-head text-[10px] font-bold tracking-[0.14em] uppercase text-muted mb-1">Season Standings</p>
    <div class="flex items-center gap-3 flex-wrap">
      <h1 class="font-head text-[28px] lg:text-[32px] font-extrabold tracking-tight leading-none">Team Standings</h1>
      {standings.provisional && (
        <span class="badge badge-warning">Provisional</span>
      )}
    </div>
    <p class="text-sm text-muted mt-2">{year} Inter Club {seriesLong}</p>
    <p class="text-sm text-muted mt-0.5">
      <span class="font-mono">{racesRun} of {races.length}</span> races run
      {racesRemaining > 0 && (
        <> · <span class="font-mono text-amber">{racesRemaining}</span> remaining</>
      )}
    </p>
  </StandingsHeader>

  <!-- Category chip bar — mobile + tablet, in the chip-bar slot (full viewport width) -->
  <ChipBar
    slot="chip-bar"
    items={standings.categories.map((cat, i) => ({
      label:  categoryById[cat.id]?.name ?? cat.id,
      target: `cat-panel-${i}`,
      active: i === 0,
    }))}
  />

  <!-- ══════════════════════════════════════════════
       DESKTOP (lg+): sticky sidebar + stacked tables
  ══════════════════════════════════════════════ -->
  <div class="hidden lg:grid grid-cols-[200px_1fr] gap-8 items-start">

    <!-- Sticky sidebar -->
    <aside class="sticky top-6 self-start">
      <p class="font-head text-[10px] font-bold tracking-[0.12em] uppercase text-muted mb-2 pl-1">Jump to category</p>
      <nav class="flex flex-col">
        {standings.categories.map((cat) => {
          const label = categoryById[cat.id]?.name ?? cat.id;
          return (
            <a
              href={`#cat-${cat.id}`}
              class="flex items-center px-3 py-2 rounded-lg no-underline text-content hover:bg-canvas border-l-2 border-transparent hover:border-amber transition-colors"
            >
              <span class="font-head text-[13px] font-bold tracking-[0.04em] uppercase">{label}</span>
            </a>
          );
        })}
      </nav>

      <!-- Race key -->
      <div class="mt-7 pt-5 border-t border-line">
        <p class="font-head text-[10px] font-bold tracking-[0.12em] uppercase text-muted mb-2.5 pl-1">Race Key</p>
        <div class="flex flex-col gap-1 pl-1">
          {races.map((race, ri) => {
            const label = race.shortName ?? race.id;
            const ran = racesRun > ri;
            const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
            return (
              <div class:list={['flex items-center gap-2 text-xs', !ran && 'opacity-50']}>
                <span class="font-mono text-[10px] font-semibold bg-canvas px-1.5 py-0.5 rounded min-w-[36px] text-center tracking-[0.04em]">
                  {label}
                </span>
                {href
                  ? <a href={href} class="text-amber hover:underline">{race.name}</a>
                  : <span>{race.name}</span>
                }
              </div>
            );
          })}
        </div>
      </div>
    </aside>

    <!-- Stacked category sections (all visible, sidebar scrolls between them) -->
    <div class="flex flex-col gap-9">
      {standings.categories.map((cat) => {
        const label = categoryById[cat.id]?.name ?? cat.id;
        return (
          <section id={`cat-${cat.id}`} class="scroll-mt-5">
            <div class="pb-3 mb-3.5 border-b-2 border-content">
              <h2 class="font-head text-[26px] font-extrabold tracking-tight leading-none">{label}</h2>
            </div>
            <table class="w-full border-collapse text-sm">
              <thead>
                <tr>
                  <th class={`${dtTh} w-9 text-center`}>#</th>
                  <th class={`${dtTh} text-left`}>Club</th>
                  {races.map((race, ri) => {
                    const ran = racesRun > ri;
                    const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                    return (
                      <th class:list={[`${dtTh} w-14 text-center`, !ran && 'opacity-50']}>
                        {href
                          ? <a href={href} class="text-amber hover:underline">{race.shortName ?? race.id}</a>
                          : (race.shortName ?? race.id)
                        }
                      </th>
                    );
                  })}
                  <th class={`${dtTh} w-16 text-right border-l-2 border-content pr-0.5`}>Total</th>
                </tr>
              </thead>
              <tbody>
                {cat.clubs.map((clubResult) => {
                  const clubName = clubById[clubResult.club]?.name ?? clubResult.club;
                  return (
                    <tr class="border-b border-line last:border-0 hover:bg-canvas/50">
                      <td class="py-2.5 px-2 text-center align-middle font-mono text-xs font-medium text-muted tabular-nums">
                        {clubResult.position}
                      </td>
                      <td class="py-2.5 px-2 align-middle">
                        <div class="font-semibold text-[14px]">{clubName}</div>
                        {clubResult.tiebreaker && (
                          <div class="font-mono text-[10px] text-muted mt-0.5 tracking-[0.04em]">{clubResult.tiebreaker}</div>
                        )}
                      </td>
                      {races.map((race, ri) => {
                        const sIdx = standingsRaceIdx[race.id];
                        const pts = sIdx !== undefined ? (clubResult.points[sIdx] ?? null) : null;
                        const ran = racesRun > ri;
                        return (
                          <td class:list={[
                            'py-2.5 px-1 text-center font-mono text-[13px] align-middle tabular-nums',
                            pts === null ? 'text-content/20' : (ran ? 'font-medium' : 'text-muted'),
                          ]}>
                            {pts ?? '—'}
                          </td>
                        );
                      })}
                      <td class="py-2.5 pl-3 pr-0.5 text-right font-mono text-[17px] font-bold align-middle border-l-2 border-content tabular-nums">
                        {clubResult.total}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </section>
        );
      })}
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       MOBILE + TABLET (<lg): chip-switched panels
       Breakpoints unified with IndividualStandingsLayout:
         Mobile  < sm (640px) — expandable cards
         Tablet  sm–lg        — table in a card
  ══════════════════════════════════════════════ -->
  <div class="lg:hidden">
    {standings.categories.map((cat, i) => {
      const label = categoryById[cat.id]?.name ?? cat.id;
      return (
        <div id={`cat-panel-${i}`} class:list={[i > 0 && 'hidden']} role="tabpanel">

          <!-- Panel heading -->
          <div class="mb-3 sm:mb-4">
            <h2 class="font-head text-[22px] sm:text-[26px] font-extrabold tracking-tight">{label}</h2>
          </div>

          <!-- ── TABLET (sm to lg): table in a card ── -->
          <div class="hidden sm:block overflow-x-auto">
            <div class="bg-surface border border-line rounded-xl overflow-hidden">
              <table class="w-full border-collapse text-sm">
                <thead>
                  <tr>
                    <th class={`${tabTh} w-10 text-center`}>#</th>
                    <th class={`${tabTh} text-left pl-2`}>Club</th>
                    {races.map((race, ri) => {
                      const ran = racesRun > ri;
                      const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                      return (
                        <th class:list={[`${tabTh} w-11 text-center`, !ran && 'opacity-55']}>
                          {href
                            ? <a href={href} class="text-amber hover:underline">{race.shortName ?? race.id}</a>
                            : (race.shortName ?? race.id)
                          }
                        </th>
                      );
                    })}
                    <th class={`${tabTh} w-16 text-right border-l-2 border-content pr-3.5`}>Total</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.clubs.map((clubResult) => {
                    const clubName = clubById[clubResult.club]?.name ?? clubResult.club;
                    return (
                      <tr class="border-b border-line last:border-0 hover:bg-canvas/50">
                        <td class="py-3 pl-3.5 pr-2 text-center align-middle font-mono text-xs font-medium text-muted tabular-nums">
                          {clubResult.position}
                        </td>
                        <td class="py-3 pl-2 pr-2 align-middle">
                          <div class="font-semibold text-[14px]">{clubName}</div>
                          {clubResult.tiebreaker && (
                            <div class="font-mono text-[10px] text-muted mt-0.5 tracking-[0.04em]">{clubResult.tiebreaker}</div>
                          )}
                        </td>
                        {races.map((race, ri) => {
                          const sIdx = standingsRaceIdx[race.id];
                          const pts = sIdx !== undefined ? (clubResult.points[sIdx] ?? null) : null;
                          return (
                            <td class:list={[
                              'py-3 px-1 text-center font-mono text-[13px] align-middle tabular-nums',
                              pts === null ? 'text-content/20' : (racesRun > ri ? 'font-medium' : 'text-muted'),
                            ]}>
                              {pts ?? '—'}
                            </td>
                          );
                        })}
                        <td class="py-3 pl-3 pr-3.5 text-right font-mono text-[16px] font-bold align-middle border-l-2 border-content tabular-nums">
                          {clubResult.total}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
            <!-- Race legend (tablet) -->
            <div class="flex flex-wrap gap-x-3.5 gap-y-1.5 pt-3.5 text-xs text-muted">
              {races.map((race, ri) => {
                const ran = racesRun > ri;
                const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                return (
                  <span class:list={['inline-flex items-center gap-1.5', !ran && 'opacity-50']}>
                    <span class="font-mono text-[10px] font-semibold bg-canvas px-1.5 py-0.5 rounded tracking-[0.04em]">{race.shortName ?? race.id}</span>
                    {href
                      ? <a href={href} class="text-amber hover:underline">{race.name}</a>
                      : <span>{race.name}</span>
                    }
                    {!ran && <span class="font-mono"> · upcoming</span>}
                  </span>
                );
              })}
            </div>
          </div>

          <!-- ── MOBILE (below sm): expandable cards ── -->
          <div class="sm:hidden pb-2">
            {cat.clubs.map((clubResult) => {
              const clubName = clubById[clubResult.club]?.name ?? clubResult.club;
              const detailId = `detail-${i}-${clubResult.club}`;
              return (
                <MobileAccordionCard detailId={detailId} position={clubResult.position}>
                  <div class="font-head text-[16px] font-bold tracking-[-0.01em] leading-[1.15] truncate">{clubName}</div>

                  <div slot="score" class="text-right shrink-0 flex flex-col items-end justify-center min-h-10">
                    <div class="font-mono text-[22px] font-medium leading-none tabular-nums">{clubResult.total}</div>
                    {clubResult.tiebreaker && (
                      <div class="font-mono text-[9px] text-muted mt-0.5 tracking-[0.04em]">{clubResult.tiebreaker}</div>
                    )}
                  </div>

                  <div slot="detail" class="grid grid-cols-7 gap-1 p-3">
                    {races.map((race) => {
                      const sIdx = standingsRaceIdx[race.id];
                      const pts = sIdx !== undefined ? (clubResult.points[sIdx] ?? null) : null;
                      const scored = pts !== null && pts > 0;
                      const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                      return (
                        <div class:list={['flex flex-col items-center gap-0.5 py-1.5 rounded-md', scored && 'bg-canvas']}>
                          {href
                            ? <a href={href} class:list={['font-head text-[9px] font-bold tracking-[0.08em]', scored ? 'text-amber' : 'text-content/20']}>{race.shortName ?? race.id}</a>
                            : <span class:list={['font-head text-[9px] font-bold tracking-[0.08em]', scored ? 'text-muted' : 'text-content/20']}>{race.shortName ?? race.id}</span>
                          }
                          <span class:list={['font-mono text-sm font-medium', scored ? 'text-content' : 'text-content/20']}>
                            {pts !== null ? pts : '—'}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                </MobileAccordionCard>
              );
            })}
          </div>

          <!-- Race key (mobile only) -->
          <div class="sm:hidden mt-4 pt-4 border-t border-line">
            <p class="font-head text-[10px] font-bold tracking-[0.12em] uppercase text-muted mb-2">Race Key</p>
            <div class="grid grid-cols-2 gap-x-3 gap-y-1">
              {races.map((race, ri) => {
                const ran = racesRun > ri;
                const href = linkedRaceIds.has(race.id) ? siteUrl(`/${series}/${year}/${race.id}/team-results`) : null;
                return (
                  <div class:list={['flex items-center gap-2 text-xs', !ran && 'opacity-60']}>
                    <span class="font-mono text-[10px] font-semibold bg-canvas px-1.5 py-0.5 rounded tracking-[0.04em] min-w-[32px] text-center">
                      {race.shortName ?? race.id}
                    </span>
                    {href
                      ? <a href={href} class="text-amber hover:underline flex-1">{race.name}</a>
                      : <span class="flex-1">{race.name}</span>
                    }
                  </div>
                );
              })}
            </div>
          </div>

        </div>
      );
    })}
  </div>

</Layout>

<script>
  // ── Category chips (mobile + tablet) ──
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip-btn');
  chips.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target!;
      chips.forEach(c => {
        const active = c === btn;
        c.classList.toggle('bg-amber',    active);
        c.classList.toggle('border-amber', active);
        c.classList.toggle('text-white',   active);
        c.classList.toggle('bg-surface',   !active);
        c.classList.toggle('border-line',  !active);
        c.classList.toggle('text-muted',   !active);
        c.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll<HTMLElement>('[id^="cat-panel-"]').forEach(panel => {
        panel.classList.toggle('hidden', panel.id !== targetId);
      });
    });
  });

</script>
