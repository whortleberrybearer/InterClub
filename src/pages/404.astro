---
import Layout from '../components/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="404 · Not Found">
  <div class="nf-outer">

    <div class="nf-inner">

      <div class="nf-eyebrow">Error · 404</div>

      <div class="nf-numeral">404</div>

      <div class="nf-grid">

        <!-- Copy + CTAs -->
        <div>
          <h1 class="nf-heading">We couldn't find that page.</h1>

          <p class="nf-body">
            It may have moved, been retired with last season's fixtures, or never existed in the first place.
          </p>

          <div class="nf-btns">
            <a href={`${base}/`} class="nf-btn-primary">Back to home</a>
            <a href={`${base}/road-gp/`} class="nf-btn-outline">Browse all races</a>
          </div>
        </div>

        <!-- Suggested links -->
        <div class="nf-suggestions">
          <div class="nf-suggestions-label">Try one of these</div>
          {[
            { label: 'Road Grand Prix', path: `${base}/road-gp/` },
            { label: 'Fell Championship', path: `${base}/fell/` },
          ].map(l => (
            <a href={l.path} class="nf-suggestion-row">
              <div>
                <div class="nf-suggestion-title">{l.label}</div>
                <div class="nf-suggestion-path">{l.path}</div>
              </div>
              <span class="nf-arrow">→</span>
            </a>
          ))}
        </div>

      </div>
    </div>

  </div>
</Layout>

<style>
  .nf-outer {
    min-height: calc(100vh - 57px - 49px);
    display: flex;
    flex-direction: column;
  }

  .nf-inner {
    flex: 1;
    padding: 48px 20px 40px;
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
  }

  .nf-eyebrow {
    font-family: var(--ff-head);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-amber);
    margin-bottom: 18px;
  }

  .nf-numeral {
    font-family: var(--ff-head);
    font-size: clamp(80px, 22vw, 320px);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: var(--color-content);
    margin-bottom: 20px;
    margin-left: -4px;
  }

  .nf-grid {
    display: grid;
    gap: 28px;
  }

  .nf-heading {
    font-family: var(--ff-head);
    font-size: clamp(1.75rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 12px;
    color: var(--color-content);
  }

  .nf-body {
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-muted);
    margin-bottom: 24px;
    max-width: 460px;
  }

  .nf-btns {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
  }

  .nf-btn-primary,
  .nf-btn-outline {
    display: block;
    font-family: var(--ff-head);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 12px 22px;
    border-radius: 8px;
    text-decoration: none;
    text-align: center;
  }

  .nf-btn-primary {
    background: var(--color-amber);
    color: #fff;
  }

  .nf-btn-outline {
    background: var(--color-surface);
    color: var(--color-content);
    border: 1px solid var(--color-line);
  }

  .nf-suggestions {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    overflow: hidden;
  }

  .nf-suggestions-label {
    padding: 14px 18px 10px;
    border-bottom: 1px solid var(--color-line);
    font-family: var(--ff-head);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .nf-suggestion-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--color-line);
    text-decoration: none;
  }

  .nf-suggestion-row:last-child {
    border-bottom: none;
  }

  .nf-suggestion-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-content);
  }

  .nf-suggestion-path {
    font-family: var(--ff-mono);
    font-size: 11px;
    color: var(--color-muted);
    margin-top: 2px;
  }

  .nf-arrow {
    color: var(--color-amber);
    font-size: 16px;
  }

  /* Desktop: side-by-side layout */
  @media (min-width: 768px) {
    .nf-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 64px;
      align-items: center;
    }

    .nf-btns {
      flex-direction: row;
    }

    .nf-btn-primary,
    .nf-btn-outline {
      display: inline-block;
    }
  }
</style>
