---
import Layout from '../components/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="404 · Not Found">
  <div class="flex flex-col" style="min-height:calc(100vh - 106px)">
    <div class="flex-1 px-5 pt-12 pb-10 max-w-[960px] mx-auto w-full">

      <p class="font-head text-[11px] font-bold tracking-[0.16em] uppercase text-amber mb-[18px]">
        Error · 404
      </p>

      <div class="font-head text-[clamp(80px,22vw,320px)] font-extrabold tracking-[-0.06em] leading-[0.85] text-content mb-5 -ml-1">
        404
      </div>

      <div class="grid gap-7 md:grid-cols-[1.1fr_1fr] md:gap-16 md:items-center">

        <!-- Copy + CTAs -->
        <div>
          <h1 class="font-head text-[clamp(1.75rem,4vw,3.5rem)] font-extrabold tracking-[-0.025em] leading-[1.05] mb-3 text-content">
            We couldn't find that page.
          </h1>
          <p class="text-[15px] leading-relaxed text-muted mb-6 max-w-[460px]">
            It may have moved, been retired with last season's fixtures, or never existed in the first place.
          </p>
          <div class="flex flex-col gap-2.5 mb-8 md:flex-row">
            <a href={`${base}/`}
               class="block text-center font-head text-sm font-bold tracking-[0.05em] uppercase px-[22px] py-3 rounded-lg bg-amber text-white no-underline md:inline-block">
              Back to home
            </a>
            <a href={`${base}/road-gp/`}
               class="block text-center font-head text-sm font-bold tracking-[0.05em] uppercase px-[22px] py-3 rounded-lg bg-surface text-content border border-line no-underline md:inline-block">
              Browse all races
            </a>
          </div>
        </div>

        <!-- Suggested links -->
        <div class="bg-surface border border-line rounded-xl overflow-hidden">
          <div class="px-[18px] pt-[14px] pb-[10px] border-b border-line font-head text-[10px] font-bold tracking-[0.14em] uppercase text-muted">
            Try one of these
          </div>
          {[
            { label: 'Road Grand Prix', path: `${base}/road-gp/` },
            { label: 'Fell Championship', path: `${base}/fell/` },
          ].map(l => (
            <a href={l.path} class="flex justify-between items-center px-[18px] py-3 border-b border-line last:border-b-0 no-underline">
              <div>
                <div class="text-sm font-medium text-content">{l.label}</div>
                <div class="font-mono text-[11px] text-muted mt-0.5">{l.path}</div>
              </div>
              <span class="text-amber text-base">→</span>
            </a>
          ))}
        </div>

      </div>
    </div>
  </div>
</Layout>
