---
import Layout from '../components/Layout.astro';
import { siteUrl } from '../lib/url';
---

<Layout title="Contact">

  <div class="-mt-8 grid md:grid-cols-[1fr_1.1fr] md:gap-16 md:items-start">

    <!-- Left: editorial header + contact meta -->
    <div class="-mx-4 px-4 bg-surface border-b border-line md:mx-0 md:px-0 md:bg-transparent md:border-none pt-5 pb-7 md:pt-8 md:pb-0 md:sticky md:top-8">
      <p class="font-head text-[11px] font-bold tracking-[0.16em] uppercase text-amber mb-3 flex items-center gap-2.5">
        <span class="inline-block w-5 h-px bg-amber"></span>
        Contact
      </p>
      <h1 class="font-head text-[clamp(2rem,5vw,3.5rem)] font-extrabold tracking-[-0.025em] leading-[1] text-content mb-4">
        Get in touch.
      </h1>
      <p class="text-[15px] leading-relaxed text-muted max-w-[380px]">
        Result query, fixture suggestion, or anything else — drop us a line and we'll get back to you.
      </p>

    </div>

    <!-- Right: form — no card on mobile, card on desktop -->
    <div class="pt-6 pb-8 md:mt-8 md:bg-surface md:border md:border-line md:rounded-[14px] md:p-7">
      <form method="POST" action={siteUrl('/contact/thank-you/')}>

        <div class="mb-[18px]">
          <label for="name" class="flex justify-between items-baseline font-head text-[11px] font-bold tracking-[0.12em] uppercase text-muted mb-1.5">
            Name
          </label>
          <input id="name" type="text" name="name" required placeholder="Your name"
            class="w-full text-[15px] px-3.5 py-[11px] border border-line rounded-[10px] bg-surface text-content outline-none focus:border-amber transition-colors font-body" />
        </div>

        <div class="mb-[18px]">
          <label for="email" class="flex justify-between items-baseline font-head text-[11px] font-bold tracking-[0.12em] uppercase text-muted mb-1.5">
            Email
          </label>
          <input id="email" type="email" name="email" required placeholder="you@example.com"
            class="w-full text-[15px] px-3.5 py-[11px] border border-line rounded-[10px] bg-surface text-content outline-none focus:border-amber transition-colors font-body" />
        </div>

        <div class="mb-[22px]">
          <label for="message" class="flex justify-between items-baseline font-head text-[11px] font-bold tracking-[0.12em] uppercase text-muted mb-1.5">
            <span>Message</span>
            <span id="char-count" class="font-mono text-[10px] font-medium tracking-[0.04em] text-muted normal-case">0 / 2000</span>
          </label>
          <textarea id="message" name="message" required rows="5" maxlength="2000"
            placeholder="Tell us what's on your mind…"
            class="w-full text-[15px] px-3.5 py-[11px] border border-line rounded-[10px] bg-surface text-content outline-none focus:border-amber transition-colors resize-y leading-relaxed font-body"
            oninput="document.getElementById('char-count').textContent = this.value.length + ' / 2000'"></textarea>
        </div>

        <!-- Mobile: full-width button -->
        <div class="flex flex-col gap-3 md:hidden">
          <button type="submit"
            class="w-full font-head text-sm font-bold tracking-[0.06em] uppercase py-[14px] rounded-lg bg-amber text-white border-none cursor-pointer">
            Send message
          </button>
        </div>

        <!-- Desktop: privacy note + button inline -->
        <div class="hidden md:flex items-center justify-between gap-4">
          <p class="font-mono text-[11px] text-muted">We never share your email.</p>
          <button type="submit"
            class="font-head text-sm font-bold tracking-[0.06em] uppercase px-[26px] py-3 rounded-lg bg-amber text-white border-none cursor-pointer whitespace-nowrap">
            Send message
          </button>
        </div>

      </form>
    </div>

  </div>

</Layout>
